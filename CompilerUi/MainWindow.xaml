<Window x:Class="CompilerUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Compiler Lexer &amp; Parser" Height="700" Width="1000" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <avalonEdit:TextEditor Name="txtCodeEditor" 
                                   FontFamily="Consolas" 
                                   FontSize="12pt" 
                                   ShowLineNumbers="True"/>
        </Border>

        <Button Grid.Row="0" Grid.Column="2" Content="ANALIZAR" 
                VerticalAlignment="Center" HorizontalAlignment="Center" 
                Width="120" Height="40" Margin="5" Click="BtnAnalizar_Click"
                Background="#A0B8D0" Foreground="White" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
            <Label Content="ERRORES" Background="#D05050" Foreground="White" FontWeight="Bold"/>
            <ListBox x:Name="lstErrores" Height="215"/>
        </StackPanel>

        <DataGrid Grid.Row="1" Grid.Column="1" x:Name="dgTokens" 
                  AutoGenerateColumns="False" Margin="5" Background="White"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="LEXEMA" Binding="{Binding Lexema}" Width="*"/>
                <DataGridTextColumn Header="TIPO" Binding="{Binding Tipo}" Width="*"/>
                <DataGridTextColumn Header="LINEA" Binding="{Binding Linea}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Grid.Column="2" Margin="5">
            <Label Content="ÁRBOL SINTÁCTICO" Background="#4A90E2" Foreground="White" FontWeight="Bold"/>
            <TreeView x:Name="treeView1" Height="215" Background="White" BorderBrush="Gray" BorderThickness="1"/>
        </StackPanel>

        <UniformGrid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Columns="5" Margin="5">
            <StackPanel Margin="2">
                <Label Content="RESERVADAS" Background="#A0B8D0" Foreground="White"/>
                <ListBox x:Name="lstReservadas" Height="120"/>
            </StackPanel>
            <StackPanel Margin="2">
                <Label Content="IDENTIFICADORES" Background="#A0B8D0" Foreground="White"/>
                <ListBox x:Name="lstIdentificadores" Height="120"/>
            </StackPanel>
            <StackPanel Margin="2">
                <Label Content="DELIMITADORES" Background="#A0B8D0" Foreground="White"/>
                <ListBox x:Name="lstDelimitadores" Height="120"/>
            </StackPanel>
            <StackPanel Margin="2">
                <Label Content="OPERADORES" Background="#A0B8D0" Foreground="White"/>
                <ListBox x:Name="lstOperadores" Height="120"/>
            </StackPanel>
            <StackPanel Margin="2">
                <Label Content="NUMEROS" Background="#A0B8D0" Foreground="White"/>
                <ListBox x:Name="lstNumeros" Height="120"/>
            </StackPanel>
        </UniformGrid>
    </Grid>
</Window>